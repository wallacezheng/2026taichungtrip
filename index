<script>
  const tabs = document.querySelectorAll('#tabs button');
  const sections = document.querySelectorAll('main > section');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      sections.forEach(s => s.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(tab.dataset.tab).classList.add('active');
    });
  });

  function toggleDay(headerEl) {
    const card = headerEl.parentElement;
    card.classList.toggle('open');
  }

  // ===== Expense Tracker =====
  let selectedPayer = 'Wallace';
  let selectedSplit = 'shared';
  let expenses = [];

  function selectPayer(name) {
    selectedPayer = name;
    document.getElementById('btnWallace').classList.toggle('selected', name === 'Wallace');
    document.getElementById('btnMing').classList.toggle('selected', name === 'Ming');
  }

  function selectSplit(type) {
    selectedSplit = type;
    document.getElementById('btnSplitShared').classList.toggle('selected', type === 'shared');
    document.getElementById('btnSplitSelf').classList.toggle('selected', type === 'self');
  }

  async function loadExpenses() {
    try {
      const result = await window.storage.get('expenses-list', true);
      expenses = result && result.value ? JSON.parse(result.value) : [];
    } catch (e) {
      expenses = [];
    }
    renderExpenses();
  }

  async function saveExpenses() {
    try {
      await window.storage.set('expenses-list', JSON.stringify(expenses), true);
    } catch (e) {
      console.error('Storage error:', e);
      alert('儲存失敗，請重試一次');
    }
  }

  async function addExpense() {
    const itemName = document.getElementById('itemInput').value.trim();
    const amount = parseFloat(document.getElementById('amountInput').value);

    if (!itemName) { alert('請輸入項目名稱'); return; }
    if (!amount || amount <= 0) { alert('請輸入正確金額'); return; }

    expenses.push({
      id: Date.now(),
      payer: selectedPayer,
      item: itemName,
      amount: amount,
      split: selectedSplit
    });

    await saveExpenses();
    document.getElementById('itemInput').value = '';
    document.getElementById('amountInput').value = '';
    renderExpenses();
  }

  async function deleteExpense(id) {
    expenses = expenses.filter(e => e.id !== id);
    await saveExpenses();
    renderExpenses();
  }

  function renderExpenses() {
    const listEl = document.getElementById('expenseList');

    if (expenses.length === 0) {
      listEl.innerHTML = '<div class="empty-state">還沒有任何支出紀錄，新增第一筆吧！</div>';
    } else {
      listEl.innerHTML = expenses.slice().reverse().map(e => {
        const splitLabel = e.split === 'shared' ? '兩人平分' : `${e.payer} 自己的花費`;
        return `
          <div class="expense-item">
            <div class="exp-left">
              <div class="exp-item-name">${escapeHtml(e.item)}</div>
              <div class="exp-meta">${e.payer} 付款 · ${splitLabel}</div>
            </div>
            <div class="exp-amount">$${e.amount.toLocaleString()}</div>
            <button class="exp-delete" onclick="deleteExpense(${e.id})">✕</button>
          </div>
        `;
      }).join('');
    }

    calculateSummary();
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function calculateSummary() {
    // Track how much each person paid that should count toward the shared pool,
    // and how much each person owes for shared items.
    let wallacePaidShared = 0;
    let mingPaidShared = 0;
    let sharedTotal = 0;

    expenses.forEach(e => {
      if (e.split === 'shared') {
        sharedTotal += e.amount;
        if (e.payer === 'Wallace') wallacePaidShared += e.amount;
        else mingPaidShared += e.amount;
      }
      // 'self' split items don't affect settlement — each person already covered their own.
    });

    const summaryAmountEl = document.getElementById('summaryAmount');
    const summarySubEl = document.getElementById('summarySub');

    if (sharedTotal === 0) {
      summaryAmountEl.textContent = '目前沒有需要分攤的支出';
      summarySubEl.textContent = '新增「兩人平分」項目後會自動結算';
      return;
    }

    const halfShare = sharedTotal / 2;
    const diff = wallacePaidShared - halfShare; // positive: Wallace overpaid, Ming owes Wallace

    if (Math.abs(diff) < 1) {
      summaryAmountEl.textContent = '兩人已平分，不需互相補款 🎉';
      summarySubEl.textContent = `共同支出總額 $${sharedTotal.toLocaleString()}，各付一半 $${halfShare.toLocaleString()}`;
    } else if (diff > 0) {
      summaryAmountEl.textContent = `Ming 需要給 Wallace $${Math.round(diff).toLocaleString()}`;
      summarySubEl.textContent = `共同支出總額 $${sharedTotal.toLocaleString()}・Wallace 已付 $${wallacePaidShared.toLocaleString()}，Ming 已付 $${mingPaidShared.toLocaleString()}`;
    } else {
      summaryAmountEl.textContent = `Wallace 需要給 Ming $${Math.round(-diff).toLocaleString()}`;
      summarySubEl.textContent = `共同支出總額 $${sharedTotal.toLocaleString()}・Wallace 已付 $${wallacePaidShared.toLocaleString()}，Ming 已付 $${mingPaidShared.toLocaleString()}`;
    }
  }

  loadExpenses();
</script>



